# Supabase 公開クライアント用（ブラウザに露出してよい値。RLS で保護される）
# 実値は Supabase ダッシュボード or `supabase` MCP の get_project_url / get_publishable_keys から取得し
# .env.local（gitignore 済み）に設定する。
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# 管理パネルのサーバ側書き込み用（秘密。ブラウザに出さない）。docs/11 で使用予定。
# SUPABASE_SERVICE_ROLE_KEY=
